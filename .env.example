# ---------------------------------------------------------------------------
# Environment configuration for AI English Mentor (backend proxy)
#
# 1. Copy this file to ".env"   ->   cp .env.example .env
# 2. Paste your real Anthropic API key below.
#
# This key is used ONLY by the backend server. It is NEVER sent to the
# frontend / browser. Keep ".env" out of git (already in .gitignore).
# ---------------------------------------------------------------------------

# 👇 OWNER: insert your Anthropic API key here
ANTHROPIC_API_KEY=

# Optional: port for the local server (defaults to 3000 if unset)
# PORT=3000
